    { test: (l) => /(window|document)\.addEventListener/.test(l) && !/(window|document)\.removeEventListener/.test(l), msg: "⚠️ MEMORY LEAK POTENCIAL: Listener global instanciado sem cleanup/removeEventListener explícito no código analisado." },
    { pattern: /alter\s+table\s+\w+\s+enable\s+row\s+level\s+security/i, excl: /create\s+policy/i, msg: "⚠️ RLS DEFAULT-DENY DETECTADO: Habilitar RLS sem definir explicitamente uma policy resultará em acesso nulo (bloqueio total). Especifique as policies no mesmo script/bloco." },
    { pattern: /if\s*\(\s*\w*Promise\w*\s*\)/, msg: "⚠️ MISUSED PROMISE: Uma variável possivelmente identificada como Promise está sendo checada diretamente em um IF. Certifique-se de comparar via `!== null` ou `!== undefined` ou aguarde-a (await)." },
    { pattern: /(increment|decrement|update)(Coupon|Stock|Balance)/, excl: /(FOR UPDATE)|(CREATE OR REPLACE FUNCTION)/, msg: "🛡️ ALERTA CRÍTICO DE ARQUITETURA: Código frontend (fora do banco) tentando alterar/mutar contadores e estoques diretamente. Isso causa Race Conditions e DoS BOLA. Mova o incremento atômico para o DB (Transação ou Trigger)." },
    { pattern: /typeof\s+window\s*!==\s*['"]undefined['"]/i, msg: "⚠️ USO INDEVIDO DO WINDOW: Checagem isolada de window pode falhar no SSR moderno ou causar confusão de contexto global. Considere utilizar 'globalThis'." },
    { pattern: /if\s*\(\s*\w+\s+(?:IS|===|==)\s+NULL\s*\)\s+(?:THEN\s+)?RAISE\s+EXCEPTION/i, msg: "⚠️ VERIFICAÇÃO PERIGOSA DE NULOS: Se o campo iterado ou selecionado pode ser um 'override', testar IS NULL/=== null pode lançar erro ignorando o fallback original. Avalie a chave primária ou 'exists_flag' separadamente." },
    { pattern: /dangerouslySetInnerHTML/i, msg: "🛡️ ALERTA CRÍTICO (XSS): Uso de dangerouslySetInnerHTML detectado. Certifique-se de que a entrada foi sanitizada adequadamente (Ex: DOMPurify)." },
    { pattern: /(AKIA[0-9A-Z]{16})|(A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}/, msg: "🛡️ COMPROMETIMENTO CRÍTICO: Chave AWS IAM detectada hardcoded. Remova imediatamente para um sistema de Vault ou variável de ambiente segura." },
    { test: (l) => /(process\.env\.\w+)/.test(l) && !/process\.env\.NODE_ENV/.test(l) && /(window\.|console\.log\(.*process\.env)/.test(l), msg: "⚠️ VAZAMENTO DE ENV: Tentativa explícita de expor uma variável de ambiente servidora direto ao objeto global/console." },
    { test: (l) => /\.on\(['"]data['"]/.test(l) && !/setEncoding\(['"]utf8['"]\)/.test(l), msg: "🛡️ ALERTA CRÍTICO: Chunking sem 'setEncoding'. Não processe streams IPC do Node sem setEncoding('utf8') prévio. Strings multibyte corrompidas causarão Unexpected end of JSON input." },
    { pattern: /\bJSON\.parse\s*\(/, excl: /try\s*\{/i, msg: "⚠️ FRAGILIDADE DE PARSING: Uso de JSON.parse detectado sem aparente bloco try/catch de proteção. Uma payload corrompida causará o crash do processo." },
    { pattern: /\bPromise\.all\s*\(/, excl: /\.catch\s*\(/i, msg: "⚠️ AVISO DE CONCORRÊNCIA: Uso de Promise.all sem .catch associado. Uma rejeição única irá abortar todas, e se não tratada, causará falha na thread. Considere Promise.allSettled." },
    { pattern: /\.forEach\s*\(\s*(?:async\s+|\(.*?\)\s*=>\s*\{\s*await)/i, msg: "⚠️ AVISO DE ASSINCRONISMO (V46): Uso de 'await' dentro de um loop '.forEach()'. O forEach não aguarda promises. Use um 'for...of' ou 'map' com Promise.all para iteração assíncrona segura." },
    { pattern: /Promise\.all\s*\(\s*\w+\.map/i, excl: /limit|chunk/i, msg: "⚠️ GARGALO DE RATE LIMIT (V46): 'Promise.all' com '.map' sem limitador de concorrência (como p-limit) ou chunks visíveis. Alta chance de erros 429 Too Many Requests em grandes vetores." },
    { pattern: /(?:const|let|var)\s+\w*[cC]ache\s*=\s*(?:\{\}|new\s+Map\(\s*\));?/, excl: /TTL|expire|clear|LRU/i, msg: "⚠️ MEMORY LEAK ASSINTÓTICO (V46): Cache global/local inicializado sem política explícita de Eviction (LRU, TTL ou Clear). Crescimento infinito poderá matar o container por OOM." },
    { test: (l) => /setInterval\s*\(/.test(l) && !/(?:const|let|var)\s+\w+\s*=\s*setInterval/.test(l), msg: "⚠️ ORPHAN INTERVAL LEAK (V46): Uso de setInterval detectado sem atribuir o retorno à uma variável. Sem a referência, você não poderá chamar clearInterval, resultando em um forte memory leak." },
    { test: (l) => /new\s+Promise\s*\(/.test(l) && !/\.catch\s*\(/.test(l) && !/try\s*\{/.test(l), msg: "⚠️ UNHANDLED REJECTION POTENCIAL (V46): Cadeia de resolução com 'new Promise' detectada sem um bloco try/catch e sem '.catch()' atrelado." },
    { test: (l) => /(fetch|axios)\s*\(\s*`.*\$\{.*\}\s*`\s*\)/i.test(l) && !/URLSearchParams|encodeURIComponent|new URL/.test(l), msg: "🛡️ SSRF PREVENTION V49.1: Detectada chamada de rede com URL construída via interpolação. Vulnerável a Server-Side Request Forgery se a variável for originada do usuário. Faça sanitize usando req.query ou escape apropriado." },
    { test: (l) => /['"]use client['"]/.test(l) && /process\.env/.test(l) && !/NEXT_PUBLIC_/.test(l), msg: "🛡️ DATA LEAK NEXT.JS V49.1: Arquivo marcado como 'use client' acessando process.env diretamente. Isso vazará no bundle do navegador! Apenas use chaves com prefixo NEXT_PUBLIC_." },
    { test: (l) => /req\.body/.test(l) && !/(?:z|yup|joi)\.object/.test(l) && !/\.(?:parse|validate)/.test(l), msg: "⚠️ ZERO-TRUST V49.1: Acesso direto a 'req.body' em contexto de servidor detectado sem um validador de schema (Zod/Yup) à vista. O payload deve ser tipado e mitigado antes de processamento lógico." },
    { test: (l) => /catch\s*\(\s*\w*\s*\)\s*\{\s*console\.error.*\}/.test(l) && !/throw|return|res\.status/.test(l), msg: "🛡️ ALERTA CRÍTICO (V49.1): Catch isolado apenas com log e sem continuação/handling de falha ou throw. O erro foi engolido." },
    { test: (l) => /catch\s*\(\s*\w*\s*\)\s*\{\s*\}/.test(l), msg: "🛡️ ALERTA CRÍTICO (V49.1): 'Silent Catch' (Swallowing Exception) detectado. Suprimir erros oculta falhas em produção. Adicione log/telemetria." },
    { pattern: /while\s*\(\s*true\s*\)/, excl: /break|return|throw|await/i, msg: "⚠️ RISCO DE INFINITE LOOP (V49.1): 'while(true)' detectado sem quebras lógicas. Pode gerar gargalos bloqueantes (DoS Local)." },
    { test: (l) => /fs\.promises\.\w+\(/.test(l) && (!l.includes('await') && !l.includes('.then') && !l.includes('.catch')), msg: "⚠️ ASYNC I/O FLUTUANTE (V49.1): Modificação de file system sem 'await' ou cadeia de promise detectada. Isso gera race conditions de I/O silenciosas e riscos de integridade." },
    { pattern: /\/(\([^)]+\)\+)+\//, msg: "🛡️ ALERTA DE SEGURANÇA (ReDoS): Expressão regular vulnerável a 'Algorithmic Complexity Attack' (ReDoS) detectada. Evite quantificadores aninhados." },
    { test: (l) => (!l.includes('await') && l.includes('async ') && l.includes(')') && l.includes('{')), msg: "⚠️ OTIMIZAÇÃO (V49.1): Função declarada como 'async' sem 'await' visível. Evite overhead de Promise." },
    { test: (l) => /(?:db|sqlite|pg)\.run\(|query\(/i.test(l) && !/await/.test(l) && !/\.then/.test(l), msg: "⚠️ ALERTA DE ASSINCRONISMO (V49.1): Chamada de banco de dados sem 'await' detectada. Isso causará Race Conditions no I/O." },
    { test: (l) => /process\.exit\(\s*0\s*\)/.test(l) && !l.includes('process.on'), msg: "⚠️ GRACEFUL SHUTDOWN (V50.0): Chamada direta e precipitada de process.exit(0). Certifique-se de liberar buffers." },
    { test: (l) => /\.includes\s*\(/.test(l) && !l.includes('typeof') && !l.includes('?'), msg: "🛡️ ZERO-TRUST JAVASCRIPT (V50.0): Execução de '.includes()' detectada em variável possivelmente indefinida. Sempre faça fallback ou optional chaining ('var?.includes') para mitigar 'Cannot read properties of undefined'." },
    { test: (l) => /req\.url\.split\(['"]\/['"]\)\.pop\(\)/.test(l) && !l.includes('path.basename') && !l.includes('replace'), msg: "🛡️ ZERO-TRUST SECURITY (V51.0): Path Traversal detected. Extrair final da URL direto para I/O permite ataques '/../../../'. Mitigue com Regex ou 'path.basename'." },
    { test: (l) => /fs\.writeFileSync/.test(l) && !/export|cli/i.test(l), msg: "⚠️ I/O BLOQUEANTE (V52.0): 'fs.writeFileSync' detectado em contexto não-CLI. Privilegie 'fs.promises.writeFile' para não travar o Node Event Loop da malha de IA." },
    { test: (l) => /await\s+Promise\.all[^S]/.test(l) && l.includes('map'), msg: "⚠️ VULNERABILIDADE DE SOBRECARGA DE BOTTLENECK (V54.1): Promise.all associado a .map detectado em escalada. A ausência de chunking ou p-limit causa exaustão simultânea de workers/DB. Quebre em lotes!" },
    { test: (l) => /catch\s*\(\s*\w*\s*\)\s*=>\s*\{\s*\}/.test(l), msg: "🛡️ ALERTA DE AUTO-SABOTAGEM (V54.1): Empty Catch / Supressão detectada. Uma promessa silenciada oculta o desmoronamento do fluxo. Repasse o tracker ou registre minimamente a exaustão." },
    { test: (l) => /\.pipe\s*\(/i.test(l) && !/stream\.pipeline/i.test(l), msg: "🛡️ OTIMIZAÇÃO I/O (V55.0/V57.0): O método '.pipe()' puro não repassa erros adequadamente (memory leaks em falha). Use 'stream.pipeline()' ou adicione tratamentos de erro explícitos para ambos lados da stream." },
    { pattern: /require\s*\(\s*['"]vm['"]\s*\)/i, msg: "⚠️ ATENÇÃO COM SANDBOX (V56.0): Importação do módulo VM do Node.js detectada. Certifique-se de que o contexto em execução não possa causar escape sandbox ou memory leaks." },
    { test: (l) => /\.write\(/i.test(l) && !/if\s*\(!.*\.write/i.test(l) && !/drain/i.test(l), msg: "⚠️ GESTÃO DE BACKPRESSURE (V57.0): Uso direto de .write() de stream detectado sem verificação condicional booleana para drenar o buffer (drain). Risco de OOM e asfixia de heap!" },
    { test: (l) => /child\.kill\(['"]SIGTERM['"]\)/.test(l), msg: "🛡️ AUTO-HEALING (V57.0): O uso de SIGTERM em subprocessos vitais pode falhar em locks do Event Loop. Substitua por SIGKILL (kill -9) para evitar zumbis bloqueantes e CPU a 100%." },
    { pattern: /Math\.random\(\)\s*\.toString\(36\)/, msg: "🛡️ ALERTA DE ENTROPIA (V60.0): Uso de Math.random() para identificadores detectado. Risco de colisão em escala. Use crypto.randomUUID()." },
    { test: (l) => l.includes('.setBlocking(true)'), msg: "🛡️ ALERTA DE EPIPE (V60.0): Chamar setBlocking(true) em stdout pode causar crash fatal (EPIPE) se o receptor desconectar no Windows. Remova e use handlers de erro." },
    { test: (l) => (l.includes('stdin') || l.includes('stdout')) && !l.includes('setEncoding') && l.includes('.on('), msg: "🛡️ PURE DATA CORRUPTION (V60.0): Manipulação de stream detectada sem .setEncoding('utf8'). Risco de fragmentação de buffer UTF-8 (EOF bug)." },
    { pattern: /Object\.assign\(\s*\{\}\s*,\s*.*/, msg: "⚠️ DESEMPENHO (V61.0): Uso de Object.assign({}, obj) em caminhos críticos gera desotimizações. Priorize object spread native { ...obj } em V8." },
    { test: (l) => /\.reduce\(\s*\(.*\)\s*=>\s*\[\s*\.\.\.\w+/.test(l), msg: "⚠️ REDUCE QUADRÁTICO (V61.0): O uso de spread syntax em loop reduce de arrays causa complexidade O(N^2). Use .push() atômico ou map()/flatMap()!" },
    { test: (l) => /catch\s*\(\s*\w+\s*\)\s*\{\s*\w+\(\w+\)\s*\}$/.test(l), msg: "🛡️ MÁSCARA DE ERRO (V61.0): Ocultação/Swallowing de erro sem expor .stack ou propagá-lo. Preserve o rastreio causal de exceções contextuais!" },
    { test: (l) => /SELECT\s+\*\s+FROM/i.test(l) && !/LIMIT/i.test(l), msg: "⚠️ OVER-FETCHING (V62.0): Uso de SELECT * sem LIMIT pode causar exaustão de I/O em produção. Selecione colunas explicitamente e pagine grandes volumes." },
    { test: (l) => /setTimeout\s*\(/.test(l) && !/(?:const|let|var)\s+\w+\s*=\s*setTimeout/.test(l), msg: "⚠️ ORPHAN TIMEOUT LEAK (V62.0): Recomenda-se armazenar a referência do timer para permitir 'clearTimeout' durante unmount ou abort." },
    { test: (l) => /useEffect\s*\(\s*\(\)\s*=>\s*\{/.test(l) && !/return\s*\(\)\s*=>\s*\{/.test(l) && /(addEventListener|setTimeout|setInterval|observe)/.test(l), msg: "⚠️ REACT UNMOUNT LEAK (V62.0): Efeito possui timer ou listener, mas não possui função de cleanup. Vazamento de memória garantido após re-renders!" },
    { test: (l) => /(?:const|let|var)\s+\w+\s*=\s*new\s+(?:Map|Set)\(\)/.test(l) && !/size|delete|clear/.test(l), msg: "⚠️ HEAP EXPLOSION RISK (V63.0): Mapa ou Set instanciado sem políticas visíveis de LRU/purgation (delete, clear) perto da lida no contexto. Risco de OOM persistente." },
    { test: (l) => /fetch\s*\(/.test(l) && !/AbortSignal|timeout/i.test(l), msg: "⚠️ ZERO-TRUST NETWORK (V64.0): Uso de 'fetch' sem 'AbortSignal' ou 'timeout'. O I/O pode congelar infinitamente se o servidor remoto não responder. Adicione timeout controller!" },
    { test: (l) => /Promise\.race\s*\(/.test(l), msg: "⚠️ PROMISE LEAK (V64.0): 'Promise.race' detectado. Cuidado: promessas perdedoras NÃO são canceladas e continuam ativas consumindo recursos e DB conexões. Requer limpeza explícita ou AbortController." },
    { test: (l) => /DELETE\s+FROM\s+\w+/i.test(l) && !/WHERE/i.test(l), msg: "🛡️ OMNI-DESTRUCTION PREVENTION (V65.0): Cláusula SQL DELETE sem WHERE detectada em raw query. Evite o wiping total da tabela integrando filtros atômicos." },
    { test: (l) => /Promise\.any\s*\(/.test(l) && !/catch\s*\(/i.test(l), msg: "⚠️ AGGREGATE ERROR LEAK (V65.0): 'Promise.any' falha emitindo um 'AggregateError'. Capturá-lo com .catch() é mandatório para evitar crashing silenciado." },
    { test: (l) => /(?:getBoundingClientRect|offsetWidth|offsetHeight|scrollWidth).*=/.test(l), msg: "⚠️ DOM RE-FLOW (V66.0): Leitura/escrita síncrona no DOM causa layout thrashing (Lentidão extrema). Use requestAnimationFrame!" },
    { pattern: /crypto\.createHash\(['"](?:md5|sha1)['"]\)/i, msg: "🛡️ CRYPTO-WEAK (V66.0): MD5/SHA1 banidos por vulnerabilidades de colisão. Migre imediatamente para 'sha256' ou 'sha512' para assinaturas." },
    { test: (l) => /<input/i.test(l) && !/maxLength=|type=['"]checkbox|type=['"]radio/i.test(l), msg: "⚠️ UNBOUNDED TEXT INPUT (V66.0): Tags <input> sem 'maxLength' limitador explícito na interface (DOM). Adicione o atributo para blindar contra input abusivos." },
    { test: (l) => /BEGIN|START\s+TRANSACTION/i.test(l) && !/COMMIT|ROLLBACK/i.test(l), msg: "⚠️ SQL TRANSACTION LEAK (V67.0): Abertura de transação sem Commit/Rollback explícito no script analisado. Risco de connection thrashing ou deadlocks!" },
    { test: (l) => /__(proto|defineGetter|defineSetter)__/i.test(l), msg: "🛡️ PROTOTYPE POLLUTION (V67.0): Referência direta a __proto__ ou getters mágicos em lógica suspeita. Sempre bloqueie chaves nocivas em payloads JSON." },
    { test: (l) => /\.split\(['"]\?['"]\)/.test(l) && !/new\s+URL/i.test(l), msg: "⚠️ PATH WEAKNESS (V67.0): Extração de queries via split('?'). Use instâncias nativas como 'new URL(url)' para parsing imune a injection ou bypass de domínios." },
    { pattern: /[^=!><]==[^=]/, msg: "⚠️ TYPE COERCION RISK (V68.0): Uso de igualdade fraca (==) detectado. Sempre use igualdade estrita (===) para estabilidade Zero-Trust de tipagem." },
    { test: (l) => /console\.\w+\(.*e\.message.*\)/.test(l) && !/console\.error\(e\)/.test(l), msg: "🛡️ TRACE MASKING (V68.0): Ocultamento de Stack Trace detectado. Registrar apenas 'e.message' perde o rastro causal da falha original. Registre 'e'." },
    { test: (l) => /style\s*=\s*\{\{\s*\w+/.test(l), msg: "⚠️ INLINE STYLE RE-RENDER (V68.0): Declarar objetos css literais no React destrói o memoization, pois aloca nova referência no JS Heap a cada render." },
    { test: (l) => /JSON\.stringify\s*\(/i.test(l) && /Set|Map/i.test(l) && !/Array\.from|\[\.\.\./i.test(l), msg: "⚠️ JSON STRINGIFY LEAK (V69.0): Set ou Map passados diretamente para JSON.stringify retornam '{}'. Converta para Array antes de serializar." },
    { test: (l) => /new\s+(?:Array|Object)\s*\(.*10000/.test(l) && !/TypedArray|Buffer/.test(l), msg: "⚠️ GC OVERLOAD POOL (V70.0): Evite criar arrays massivos de literais em JS que afogam o Garbage Collector; utilize TypedArrays ou Buffers nativos." },
    { test: (l) => /\.emit\(['"]error['"]\s*,/.test(l) && !/\.on\(['"]error['"]/.test(l), msg: "🛡️ UNHANDLED EVENT EMITTER FATALITY (V71.0): Emitir erro sem listener causa crash instantâneo não-rastreável no Node.js." },
    { test: (l) => /new\s+Promise\s*\(\s*(?:[a-zA-Z_]\w*)\s*=>/.test(l) && !/reject\s*\(/.test(l), msg: "⚠️ PROMISE PERMA-LOCK (V71.0): Criar Promise apenas com 'resolve' (sem 'reject') causará travamento eterno de thread/conexões se ocorrer falha isolada." },
    { test: (l) => /fs\.promises\.readFile/i.test(l) && !/['"]utf-?8['"]/i.test(l), msg: "⚠️ BINARY READ LEAK (V71.0): fs.promises.readFile sem 'utf8' preenche o Heap com raw Buffers. Sempre defina 'utf8' para text extraction." },
    { test: (l) => /JSON\.parse\(.*req\.body.*\)/.test(l) && !/limit/.test(l), msg: "🛡️ DOS PAYLOAD SHIELD (V71.0): Fazer JSON.parse de requisições de origem anônima sem limites restritos causa asfixia instantânea de thread/OOM." },
    { test: (l) => /new\s+WebSocket\(|wss?:\/\//i.test(l) && !/ping|pong|heartbeat|setInterval/i.test(l), msg: "⚠️ WEBSOCKETS KEEP-ALIVE LEAK (V72.0): Socket aberto sem mechanism de Heartbeat (Ping/Pong) criará conexões fantasmas (half-open) afogando o fd limit do servidor." },
    { test: (l) => /replace\(\s*\/<\[\^>\]\*>\//.test(l), msg: "🛡️ REDOS NA SANITIZAÇÃO (V72.0): Uso de Regex crua para limpar HTML pode engasgar a CPU com payloads elaborados. Use DOMPurify ou sanitize-html." },
    { test: (l) => /Buffer\.allocUnsafe\s*\(/i.test(l) && !/fill\s*\(/i.test(l), msg: "🛡️ MEMORY FRAGMENT LEAK (V72.0): Chamar Buffer.allocUnsafe sem sobrescrever imediatemente preenche a memória com dados velhos (possíveis segredos na RAM). Troque para Buffer.alloc()." },
    { test: (l) => /await\s+(.*\()/.test(l) && /return\s+.*await/.test(l) && /async\s+function/.test(l), msg: "⚠️ UNBOUNDED ASYNC RECURSION (V72.0): Risco de falha silenciosa Stack Size Exceeded detectado em fluxo assíncrono." },
    { test: (l) => /(Object|Array|String|Number)\.prototype\.\w+\s*=/.test(l), msg: "🛡️ PROTOTYPE MUTATION (V73.0): Modificar protótipos globais destrói a integridade do ambiente isolado. Veto absoluto a Monkey Patching." },
    { test: (l) => /process\.exit\(\s*1\s*\)/.test(l) && !/if\s*\(\s*require\.main\s*===/.test(l), msg: "⚠️ LIBRARY FATAL EXIT (V73.0): Invocar process.exit(1) dentro de um módulo/SDK derruba o Master Process (Sistema Principal). Lance um Throw Error ou rejeite a promise em vez de matar todo o processo hospedeiro." },
    { test: (l) => /\bdebugger;\b/.test(l), msg: "🛡️ DEBUGGER TRAP DEPLOYMENT (V74.0): Inclusão da palavra-chave 'debugger;' abortará o Event Loop na V8 sob debug (Thread bloqueada infinitamente). Remova para Deployments Autônomos!" },
    { test: (l) => /function\s*\*\s*\w+/.test(l) && !/yield/.test(l), msg: "⚠️ GENERATOR LEAK (V74.0): Declaração de função generator (function*) sem comando 'yield'. Possível erro de boilerplate causando overhead do iterador." },
    { test: (l) => /JSON\.stringify\s*\(/i.test(l) && !/(?:stringifySafe|replacer|\[Circular\])/i.test(l) && /(req|res|error|window|document)/i.test(l), msg: "⚠️ CIRCULAR JSON LEAK (V75.0): JSON.stringify em objetos possivelmente circulares (req/res/erros/DOM). Risco de Stack Overflow (TypeError: Converting circular structure to JSON). Use serializador seguro." },
    { test: (l) => /catch\s*\(\s*\w*\s*\)\s*\{.*await\s+\w+\(.*\}.*catch/i.test(l), msg: "⚠️ UNBOUNDED RETRY LEAK (V75.0): Mecanismo de Retry Assíncrono detectado sem limitação máxima (Max Retries). Risco de laço infinito de retry na rede!" },
    { test: (l) => /\.sort\(\s*\(.*\)\s*=>/i.test(l) && /(rows|data|results)/i.test(l) && !/limit/i.test(l), msg: "⚠️ IN-MEMORY SORT BOTTLENECK (V75.0): Sorting (.sort()) detectado no lado Node in-memory para dados DB. Transfira a carga ordenando por ORDER BY no SQL nativo." },
    { test: (l) => /\.map\(\s*\(.*\)\s*=>\s*(?:<[A-Z]|\(\s*<[A-Z])/i.test(l) && !/key\s*=/i.test(l), msg: "⚠️ REACT MISSING KEY (V75.0): Listagem React gerada via .map sem atributo 'key'. Risco de re-renders de alta latência e desarranjo de DOM." },
    { test: (l) => /\.replaceAll\(\s*\/.*[+*^$]\{/i.test(l), msg: "🛡️ OMNI-REDOS VULNERABILITY (V75.0): replaceAll com Regex altamente dinâmico/recursivo (+*{}). Prefira indexOf loop ou re-escreva para string segura contra complexidade exponencial." },
    { test: (l) => /for\s*\(.*(in|of).*\{\s*.*(\.find\(|\.filter\()/i.test(l), msg: "⚠️ O(1) BOTTLENECK AWARENESS (V79.0.0): Detectado uso de find/filter O(N) de array dentro de um loop. Carga exaustiva O(N^2). Indexe os itens em um Map ou Record fora do loop primeiro para acesso O(1)." },
    { test: (l) => /while\s*\(\s*.*\s*\)\s*\{\s*[^}await]*\}/i.test(l) && !l.includes('crypto'), msg: "⚠️ EVENT LOOP STARVATION PREVENT (V79.0.0): Laço while() possivelmente extenso detectado sem chamadas assíncronas (awaits). Pode bloquear o thread da V8. Incorpore 'await new Promise(r => setImmediate(r))' se processar grandes buffers." },
    { test: (l) => /arena/i.test(l) && /route/i.test(l), msg: "🧠 SWARM MOE OPTIMIZATION (V79.0.0): Lógica de roteamento do Arena detectada. Sempre inclua feedback do Validator Model para evitar alucinações de sub-agentes soltos." },
    { test: (l) => /readFileSync/i.test(l) && /import/i.test(l), msg: "🛡️ AST REQUIRE SHIELD (V79.0.0): Tentar parsear o source inteiramente manual em um arquivo usando readFileSync pode quebrar em grandes monolitos. Prefira o Ninja AST Tracer nativo." },
    { test: (l) => /grep_search\s*\(|run_command\s*\(\s*['"`]grep/i.test(l) && /child_process\.|exec\(|spawn\(/i.test(l), msg: "🛡️ AGENTIC TOOL OVERRIDE (V79.0.0): Chamada manual de comandos de busca raw detectada. Sempre priorize as MCP Tools de busca exatas (grep_search) em detrimento de subprocessos Bash, economizando o Event Loop e fortalecendo o uso Nativo do Agente." },
    { test: (l) => /query_arena_ai\(.*query_arena_ai/i.test(l) && /await/i.test(l), msg: "⚠️ SWARM ANTI-LOOP (V79.0.0): Detectada recursividade cruzada entre subservidores Swarm. Risco de chamadas infinitas ao Arena AI! Utilize sessões desacopladas com Circuit Breakers." },
    { test: (l) => /JSON\.parse\(.*toString\(\)\)/.test(l) && /d\.toString/i.test(l) && /process\.stdin/i.test(l), msg: "🛡️ STDIN STREAMING LEAK (V79.0.0): Jamais realize JSON.parse diretamente em parcelas avulsas (chunk of buffer) do STDIN. Junte o buffer na quebra de linha ('\\n') antes." },
    { test: (l) => /Math\.random\(\)\s*\*\s*\d+/.test(l) && !/(?:Math\.floor|Math\.round|Math\.ceil|parseInt)/.test(l), msg: "⚠️ FLOAT LEAK (V79.0.0): Multiplicação de Math.random() sem truncamento. Pode injetar frações flutuantes no banco, em primary keys ou iteradores. Envolva com Math.floor()." },
