    { test: (l) => /(?:const|let|var)\s+\w+\s*=\s*\[.*\]\s*;\s*while\s*\(.*length.*<.*\)/, msg: "🛡️ AGENTIC HALLUCINATION LOOP PREVENT (V79.0.0): Estruturas 'while' baseadas no acréscimo de output de modelos probabilísticos correm extremo risco de laço infinito devido aos context cut-offs. Amarre sempre um Circuit Breaker com limitação linear dura." },
    { test: (l) => /mcp_.+_diagnose\s*\(/.test(l) && /(while\s*\(true\)|setInterval)/.test(l), msg: "🧠 OMNI-OBSERVER SHIELD (V79.0.0): Pollings agressivos ao subsistema de diagnóstico. Use pub/sub reativo para arquiteturas agenticas escaláveis em vez de asfixiar o Kernel de telemetria." },
    { test: (l) => /JSON\.stringify\s*\(\s*.*(?:content|text|payload).*\)/i.test(l) && /length\s*>\s*(?:[1-9]\d{4,})/.test(l), msg: "🛡️ SWARM CONTEXT LEAK (V79.0.0): Vetores JSON gigantescos submetidos a artefatos de IA sobrecarregam a Janela de Contexto (OOM Context-Cutoff/Alucinações). Limite ou pagine." },
    { test: (l) => /fs\.writeFileSync/i.test(l) && !/multi_replace_file_content|replace/i.test(l), msg: "🛡️ AGENTIC STRICT EDIT CHAIN (V79.0.0): O agente não deve reescrever a totalidade de arquivos massivos (> 200 linhas). Utilize operações granulares/diffs para prevenir exaustão cerebral ou desastres." },
    { test: (l) => /\.pipe\s*\(\s*process\.stdout\s*\)/.test(l) && !/\.on\(['"]error['"]/.test(l), msg: "🛡️ [V79.0.0 AGENTIC-SINGULARITY] BUFFER DRAIN ASPHYXIATION: Stream piped direto para stdout sem handler de erro! Crashará no primeiro EPIPE do OS." },
