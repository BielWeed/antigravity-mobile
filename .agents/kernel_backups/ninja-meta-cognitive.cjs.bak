    { test: (l) => /fs\.(?:existsSync|readFileSync|statSync)/i.test(l) && /while|for/i.test(l), msg: "🛡️ [V80.0.0 SINGULARITY-NEXUS] SYNCHRONOUS I/O STARVATION: Operação fs.*Sync atômica detectada dentro de um loop exaustivo! Isso bloqueia o Event Loop inteiro para todo o ecossistema. Privilegie batch processing assíncrono." },
    { test: (l) => /query_arena_ai/i.test(l) && /await|then/i.test(l) && !/circuit_breaker|timeout|abort/i.test(l), msg: "🧠 [V80.0.0 SINGULARITY-NEXUS] MOE OMNI-LOCK PREVENTION: Chamada para Arena AI Validator model sem circuit breaker. Se o orquestrador Swarm falhar, a cascata causará paralisia neural (Deadlock)." },
    { test: (l) => /\.reduce\(\s*\(.*\)\s*=>\s*\[\s*\.\.\./i.test(l), msg: "⚠️ [V80.0.0 SINGULARITY-NEXUS] O(N^3) HIDDEN SCALABILITY COLLAPSE: Propagação contígua e aninhada de object spread ... dentro de reduce(). Destruição silenciosa de performance V8. Mute a variável diretamente." },
    { test: (l) => /Buffer\.concat\(\s*\[.*\]\s*\)/i.test(l) && /loop|forEach|map/i.test(l), msg: "🛡️ [V80.0.0 SINGULARITY-NEXUS] V8 GC OVERFLOW: Múltiplos Buffer.concat interativos dentro de um loop causam alocação severa de RAM. Use um único Buffer.concat para o Array condensado no exterior do loop." },
    { test: (l) => /fs\.readFileSync/i.test(l) && !/utf-?8/i.test(l) && /\.length/.test(l), msg: "⚠️ [V80.0.0 OMNI-NEXUS TRANSCENDENCE] MASSIVE BUFFER LEAK: Leitura de arquivos síncrona alocada no Heap sem codificação, e aferindo .length diretamente no buffer. Fragmentação fatal garantida em grandes massas de log." },
    { test: (l) => /new\s+Object\(\)/i.test(l), msg: "⚠️ [V80.0.0 OMNI-NEXUS TRANSCENDENCE] PROTOTYPE CHAIN POLLUTION: Uso de invocação orientada a função para Objectos primitivos 'new Object()'. Requer 'Object.create(null)' para dicionários totalmente isolados e sem getters __proto__." },
    { test: (l) => /Promise\.all\s*\(\s*\w+\s*\.map/i.test(l) && !/limit/i.test(l) && /await|chunk/i.test(l), msg: "🛡️ [V80.0.0 OMNI-NEXUS TRANSCENDENCE] UNCHUNKED PROMISE EXPLOSION: Detecção heurística de Promise.all massivo varrendo coleções sem agrupamento. O pool de workers DB será sufocado e resultará em Connection Reset by Peer." },
