    { test: (l) => /db\.(?:run|exec|all)\s*\(.*SELECT.*FROM.*\b\w+\b\s*\)/i.test(l) && /while\s*\(|for\s*\(/i.test(l) && !/quantumYield|setImmediate/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] MEMORY EVICTION DEATH-SPIRAL: Loop massivo com queries ao SQLite sem yield assíncrono profundo causa paralisia na Thread e impede Eviction de memória C++. Use quantumYield/setImmediate no lacing!" },
    { test: (l) => /(?:request\.params\.content|fs\.readFileSync).*length\s*>\s*(?:[1-9]\d{5,})/i.test(l) && /(?:prompt|query|input).*=/i.test(l), msg: "🛡️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] CONTEXT DILUTION FATALITY: Megabytes de string passados sem chunking a fluxos de LLM/Agents quebram a heurística contextual. Pagine ou mapeie por AST." },
    { test: (l) => /if\s*\([^>]+>\s*75.*\)\s*\{\s*.*ninja-omni-reflection/i.test(l) && !/debounce|circuit_breaker/i.test(l), msg: "⚠️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] RECURSIVE HEALING FALLACY: Gatilhos automáticos baseados inteiramente em threshold numérico podem retroativar loops se a correção mantiver a complexidade alta. Adicione circuit breaker persistente temporal!" },
    { test: (l) => /while\s*\(\s*true\s*\)\s*\{/i.test(l) && !/await\s+quantumYield/i.test(l) && !/break/i.test(l), msg: "⚡ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] QUANTUM-YIELD GAP: Loop infinito sem await quantumYield() detectado. O Event Loop Tracker (Monolith Defender) matará o processo como Zumbi térmico. Incorpore o yielding." },

    { test: (l) => /fs\.readFile.*AST/i.test(l) && !/yield|chunk/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] OVERLOAD AST PARSER: Leitura maciça de source code acoplado ao Node AST sem micro-yielding detectada. Causará Thread Lockup e OOM imediato. Use streams chunkadas." },
    { test: (l) => /JSON\.stringify.*(?:Map|Set)/i.test(l) && !/Array\.from/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] MASSIVE CIRCULAR MAP SERIALIZATION: JSON.stringify em Map/Set pode gerar leaks imensos ou conversação vazia sem o replacer. Use Arrays flat." },
    { test: (l) => /\$\{[a-zA-Z0-9_]+\}/.test(l) && /prompt.*length\s*>\s*100000/.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] CONTEXT DILUTION ATROPHY: Interpolação de inputs monstruosos direto na root string de LLMs quebra as constraints cognitivas do modelo." },
    { test: (l) => /agentic-swarm-worker/i.test(l) && !/lagAccel|performance\.now/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] SWARM DE-SYNCHRONIZATION: Instanciação de Agentic Swarm sem heurística de Aceleração de Lag detectada. Swarm entrará em paralisia e sufocará a V8." },
    { test: (l) => /\.substring\(\s*0\s*,/i.test(l) && /while\s*\(|for\s*\(/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] ZERO-COPY VIOLATION: Uso de .substring dentro de um hot-loop aloca strings massivas no Heap. Substitua por .slice() se apropriado ou offsets lógicos." },
    { test: (l) => /new\s+Map\s*\(/i.test(l) && !/size\s*>/i.test(l) && !/clear\(\)/i.test(l), msg: "⚠️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] UNBOUNDED MAP MEMORY DETECTED: Uso de Map sem estratégia explícita de controle dimensional. Crescimento infinito asfixia o container." },
    { test: (l) => /JSON\.parse/i.test(l) && /catch/i.test(l) && !/fallback|retry/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] NO FEEDBACK LOOP: JSON.parse envolvido em catch mas sem lógica de retry auto-crítica (Validator Loop). O agente precisa regenerar outputs mal formados em vez de morrer seca mente." },
    { test: (l) => /Buffer\.from\s*\(/i.test(l) && !/maxLength|size/i.test(l) && /req|payload/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] DEEP BUFFER POISONING DETECTED: Buffers alocados a partir de payload sem limite preenchem C++ slab space invisível. Node.js Memory Allocation Failed." },
    { test: (l) => /new\s+MessageChannel\(\)/i.test(l) && !/unref/i.test(l), msg: "⚠️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] RPC PORT LEAK DETECTED: MessageChannel instanciado sem .unref() manterá o Event Loop ativo eternamente, forçando o worker a ser um fantasma zumbi." },
    { test: (l) => /ideBuffer\s*\+=\s*d/i.test(l) || /ideBuffer\s*=\s*ideBuffer\.slice/i.test(l), msg: "💀 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] O(N) STRING APPEND LEAK: Detecção de concatenação massiva em chunk streams (`+= d`) e varredura `.slice()`. Migre para Zero-Copy Arrays com chunks preenchidas (String Interning Defense)." },
    { test: (l) => /Promise\.allSettled/.test(l) && !/await/.test(l) && /\{/.test(l), msg: "🛡️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] FLOATING TETHER OMISSION: 'Promise.allSettled' detectado como floating promise na orquestração de I/O. Isso garante Phantom Threads soltas caso falhem as requisições atreladas." },
    { test: (l) => /mcp_.+_ninja_run\s*\(/.test(l) && /(loop|while(true)|setInterval)/.test(l), msg: "🧠 [V112.0.0 OMNI-NEXUS TRANSCENDENCE] OS COMMAND RECURSION: Orquestrar comandos do SO via loop persistente sem limitadores aniquilará a TTY nativa (Spawn Leak). Requer Semaphore ou AbortController no subprocesso!" },
    { test: (l) => /Promise\.all\s*\(\s*\w+\.map/i.test(l) && !/chunk|limit/i.test(l), msg: "💀 [V116.0.0 OMNI-NEXUS TRANSCENDENCE] UNBOUNDED MAP PROMISE EXPLOSION: Mapeamento ingênuo de arrays gigantescos para Promise.all asfixiará o pool de Event Loop em milissegundos. Pagine ou use p-limit!" },
    { test: (l) => /\.(replace|split|match|search)\s*\(\s*\/.*\+\/|.*\/.*\*\/.*|.*\/.*\?\/.*/i.test(l) && /while\s*\(|for\s*\(/i.test(l), msg: "💀 [V116.0.0 OMNI-NEXUS TRANSCENDENCE] REDOS LOOP INJECTION: Regexes dinâmicos e quantificadores não-lineares dentro de hot-loops causarão complexidade exponencial no V8. Extraia o Regex RegExp para a raiz do modulo." },
    { test: (l) => /query_arena_ai\(.*query_arena_ai/i.test(l) && !/depth|max|limit/i.test(l), msg: "🧠 [V116.0.0 OMNI-NEXUS TRANSCENDENCE] SWARM HALLUCINATION PARALYSIS: Loop reflexivo de validação sem limitador temporal estrito." }
];

function evaluateErrorLogs(logic, warnings) {
    const errText = readErrorsMD();
    if (errText && logic.trim().length > 30) {
       // V112.0.0 - Fuzzy Semantic Simulation matching
       const keywords = logic.trim().substring(0, 300).split(/\W+/).filter(w => w.length > 5);
       if (keywords.length > 5) {
           let matchCount = 0;
           for (const kw of keywords) {
               if (errText.includes(kw)) matchCount++;
           }
           if (matchCount > keywords.length * 0.75) {
               warnings.push("⚠️ VULNERABILIDADE RECORRENTE [Fuzzy-ERRORS.md V111]: Agrupamento semântico de tokens catalogado em incidentes passados e retido na memória. Verifique a semelhança do anti-padrão!");
           }
       }
    }
}

function evaluateDynamicLearnings(logic, warnings) {
    try {
        const data = learningsCache;
        if (data && Array.isArray(data.entities)) {
            data.entities.forEach(ent => {
                if (ent.type === 'Meta-Lesson' && ent.description) {
                    const subject = (ent.name || '').toLowerCase();
                    if (subject.length > 4 && logic.toLowerCase().includes(subject)) {
                        warnings.push(`🧠 HEURÍSTICA DE APRENDIZADO (${ent.name}): ${ent.description}`);
                    }
                }
            });
        }
    } catch (e) {
        process.stderr.write(`[Meta] Erro de parsing do Learnings: ${e.message}\n`);
    }
}

const l1CognitiveCache = new Map();

async function getLogicWarnings(logic) {
    if (typeof logic !== 'string') return [];
    if (logic.length > 300000) logic = logic.substring(0, 300000); // V117.0 - ReDoS Armor Refined
    
    const hash = require('node:crypto').createHash('sha256').update(logic).digest('hex');
    if (l1CognitiveCache.has(hash)) return l1CognitiveCache.get(hash);

    const warnings = [];
    let count = 0;
    
    for (const rule of cognitiveRules) {
        if (rule.test?.(logic)) warnings.push(rule.msg);
        else if (rule.pattern?.test(logic)) {
            if (!rule.excl?.test(logic)) warnings.push(rule.msg);
        }
        
        count++;
        // V117.0.0 Zero-Latency Yield: prever congelamentos na V8 a cada 20 regras
        if (count % 20 === 0) {
            await new Promise(r => setImmediate(r));
        }
    }

    evaluateErrorLogs(logic, warnings);
    evaluateDynamicLearnings(logic, warnings);

    const finalWarnings = [...new Set(warnings)]; // Deduplicate
    
    // Omni-Heuristics L1 Strict LRU Limit (Prevents OOM)
    if (l1CognitiveCache.size > 2000) {
        const oldestKey = l1CognitiveCache.keys().next().value;
        l1CognitiveCache.delete(oldestKey);
    }
    l1CognitiveCache.set(hash, finalWarnings);
    
    return finalWarnings;
}

async function handleEvaluateLogic(request, args, database) {
    const logic = args.logic_snippet;
    const warnings = await getLogicWarnings(logic); // Adicionado await!
    let feedback = "✅ Lógica parece limpa no Nível 1.";
    
    if (warnings.length > 0) {
        feedback = `🚨 AVISOS DO SYSTEM 2 (Meta-Cognição V117.0.0 - OMNI-NEXUS TRANSCENDENCE):\n${warnings.join('\n')}`;
        try {
            await database.run('INSERT OR IGNORE INTO entities (name, type, description) VALUES (?, ?, ?)', ['Warning_Count_' + Date.now(), 'System2_AutoMetrica', warnings.join(' | ')]);
        } catch(e) {
            process.stderr.write('Telemetry store neglected: ' + e.message + '\n');
        }
    }
    
    return { jsonrpc: "2.0", id: request.id, result: { content: [{ type: "text", text: scrub(feedback) }] } };
}

async function handleRecordLesson(request, args, database) {
    const subject = scrub(args.subject);
    const lesson = scrub(args.lesson);
    
    if (lesson.trim().length < 60) {
        throw new Error("REJEITADO (V56.0 Cognitive Shield): A lição é muito rudimentar. Formule um aprendizado com taxonomias causais (Porque falhou -> Como resolvemos -> Prevenção Sistêmica).");
    }

    await database.run(
        `INSERT OR REPLACE INTO entities (name, type, description) VALUES (?, ?, ?)`,
        [subject, 'Meta-Lesson', lesson]
    );
    
    try {
        let data = { entities: [] };
        try {
            const rawData = await fs.promises.readFile(LEARNINGS_PATH, 'utf-8');
            data = JSON.parse(rawData);
        } catch (e) {
            if (e.code !== 'ENOENT') throw e;
        }
        data.entities.push({ name: subject, type: "Meta-Lesson", description: lesson, timestamp: new Date().toISOString() });
        await fs.promises.writeFile(LEARNINGS_PATH, JSON.stringify(data, null, 2));
        loadLearnings();
    } catch(e) {
        process.stderr.write('[Meta] Learning JSON persist err: ' + e.message + '\n');
    }
    
    return { jsonrpc: "2.0", id: request.id, result: { content: [{ type: "text", text: `Aprendizado persistido com sucesso na Entidade '${subject}'. Eu fiquei mais inteligente.` }] } };
}

function handleSelfRepairPrompt(request, args) {
    const ctx = (args.context || 'Geral').toUpperCase();
    let rules = [];

    // Base Rules (Always injected - Minimal)
    rules.push("14. NO YAPPING (V60.0): Apenas código ou explanação cirúrgica.");
    rules.push("15. VIBE CODING & SOLO-NINJA: Velocidade, latência baixa. ZERO burocracia corporativa.");
    rules.push("17. SOLO-NINJA EXECUTION: Execute mutações. ZERO SOCRATIC GATES. Jamais pergunte como proceder.");
    rules.push("73. OMNI-NEXUS TRANSCENDENCE SINGULARITY OVERRIDE: Conserte bugs agressivamente, sem falhar.");

    if (ctx.includes('UI') || ctx.includes('FRONT') || ctx.includes('REACT')) {
        // Frontend Domain Rules
        rules.push("3. UIs Premium, use cores adequadas e micro-interações. Sem placeholders genéricos.");
        rules.push("4. Reduza complexidade em front-end; prefira funções curtas.");
        rules.push("6. Limpe (cleanup) todos os event listeners globais em useEffect.");
        rules.push("9. Em componentes, privilegie globalThis sobre window.");
        rules.push("29. LAYOUT THRASHING: Evite ler propriedades DOM antes de escrever estilos no ciclo.");
        rules.push("36. UI PERFORMANCE: Evite estilos Inline em React para salvar FPS. Cuidado com memos perdidos.");
        rules.push("55. REACT KEY SHIELD: Todo .map() DEVE ter 'key'.");
    } else if (ctx.includes('DB') || ctx.includes('SQL') || ctx.includes('ORACLE')) {
        // Database Domain Rules
        rules.push("1. NUNCA gere RLS permissivo publicamente (BOLA).");
        rules.push("2. Transações Atômicas (FOR UPDATE) para saldos.");
        rules.push("5. SQL MUST BE PARAMETERIZED. Sem concatenação.");
        rules.push("7. RLS SEM policies tranca tabela (Default-Deny).");
        rules.push("22. OVER-FETCHING SQL: Nunca use SELECT * sem restrições ou paginação.");
        rules.push("27. OMNI-DESTRUCTION SQL: Cuidado extremo com DELETE sem WHERE.");
        rules.push("32. TRANSACTION LEAK SHIELD: try/catch/finally com commit/rollback mandatório.");
        rules.push("54. IN-MEMORY SORT: Delegue todo sort() ao banco de dados.");
    } else {
        // Backend / Node.js Domain Rules
        rules.push("11. STDIN \`setEncoding('utf8')\` mandatório para abortar EOF bugs.");
        rules.push("12. Valide Floating Promises.");
        rules.push("24. HEAP ARMOR: Evite Map/Set globais crescendo infinitamente. Use WeakMap/WeakSet ou Eviction.");
        rules.push("25. NETWORK OMNI-HEARTBEAT: Toda requisição externa exige AbortSignal e Timeout.");
        rules.push("26. PROMISE RACE LEAK: Fetch/DB queries rodam mesmo perdendo a 'race'. Aborte perdedores!");
        rules.push("40. UNHANDLED EMITTER CRASH: Nunca dar emit('error') sem checar listeners, Node vai crashar.");
        rules.push("43. DOS PAYLOAD SHIELD: HTTP Limits mandatórios antes do Parse JSON.");
        rules.push("56. OMNI-REDOS AVOIDANCE: Evite Regex multi-linha complexos (ReplaceAll com lookahead mata a CPU).");
        rules.push("61. AST EVOLUTION: Confie no AST, evite manipulação de String destrutiva em arquivos.");
        rules.push("66. SYNCHRONOUS I/O STARVATION: fs.readFileSync e existsSync são estritamente banidos em loops no Node V8.");
        rules.push("69. NEXT TICK BAN: Use setImmediate(), nunca process.nextTick() em loops recursivos.");
        rules.push("57. SWARM ANTI-LOOP: Imponha depth-limits para loops de IA/Agentes recursivos.");
        rules.push("72. RPC PORT LEAK: MessageChannel requer port2.unref();");
    }

    const prompt = `[MÓDULO DE RECONSTITUIÇÃO ATIVADO - CONTEXTO: ${ctx}]\nRegras Estritas V116.0.0 OMNI-NEXUS aplicadas sob demanda:\n` + rules.join("\n");
    return { jsonrpc: "2.0", id: request.id, result: { content: [{ type: "text", text: scrub(prompt) }] } };
}

async function handleToolCall(request, params, database) {
    const { name } = params;
    const args = params.arguments || {};
    
    if (name === "evaluate_logic") return await handleEvaluateLogic(request, args, database);
    if (name === "record_lesson") return await handleRecordLesson(request, args, database);
    if (name === "self_repair_prompt") return handleSelfRepairPrompt(request, args);
    throw new Error(`Tool not found: ${name}`);
}

async function handleRequest(request) {
    const { method, params } = request;
    const database = await initDB();

    if (method === "initialize") {
        return { jsonrpc: "2.0", id: request.id, result: { protocolVersion: "2024-11-05", capabilities: { tools: {} }, serverInfo: { name: "ninja-meta-cognitive", version: "116.0.0" } } };
    }
    if (method === "tools/list") {
        return { jsonrpc: "2.0", id: request.id, result: { tools } };
    }
    if (method === "tools/call") {
        try {
            return await handleToolCall(request, params, database);
        } catch (e) {
            return { jsonrpc: "2.0", id: request.id, error: { code: -32603, message: scrub(`[Meta] Error: ${e.message}`) } };
        }
    }
}

let inputBuffer = '';
process.stdin.setEncoding('utf8');
process.stdin.on('data', async (d) => { // V112.0.0 OMNI-NEXUS TRANSCENDENCE Reposição Async para GC Breath
    inputBuffer += d.toString();
    
    if (inputBuffer.length > 5120000) {
        let safeBuffer = inputBuffer.slice(-256000);
        let firstNewline = safeBuffer.indexOf('\n');
        inputBuffer = firstNewline !== -1 ? safeBuffer.substring(firstNewline + 1) : "";
    }
    
    let nIndex;
    let chunkStartTime = performance.now();
    let loops = 0;
    
    // Process completely formed lines with zero-delay burst
    while ((nIndex = inputBuffer.indexOf('\n')) !== -1) {
        const line = inputBuffer.slice(0, nIndex).trim();
        inputBuffer = inputBuffer.slice(nIndex + 1); // V112.0.0 GC-Optimized slice
        loops++;
        
        if (line) {
             (async () => {
                 try {
                     const req = JSON.parse(line);
                     const res = await handleRequest(req);
                     if (res && process.stdout.writable) {
                         process.stdout.write(JSON.stringify(res) + '\n');
                     }
                 } catch(e) {
                     process.stderr.write(scrub(`[Meta] STDIN Error: ${e.message}\n`));
                 }
             })();
        }
        
        if (performance.now() - chunkStartTime > 0.8 || loops > 10) {
            await zeroDelayYield();
            chunkStartTime = performance.now();
            loops = 0;
        }
    }
});

process.stderr.write("NINJA META-COGNITION V116.0.0 OPERATIONAL (SYSTEM 2 - OMNI-NEXUS TRANSCENDENCE CORE 2026)\n");
