    { test: (l) => /fs\.(?:read|write)FileSync/.test(l) && /ninja-.*\.js/.test(l), msg: "⚡ [V82.0.0 SINGULARITY-OMNI-FLOW] AST BLOCK DIAGNOSTIC: fs.readFileSync bloqueou 285ms no kernel. Sempre utilize hooks await fs.promises em módulos ninja nativos." },
    { test: (l) => /while\s*\(.*(true|1)\s*\)/i.test(l) && /read_file|grep_search|run_command|replace_file_content/i.test(l) && !/await\s+circuit_breaker/i.test(l), msg: "🛡️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] AGENTIC INFINITE MCP LOOP: Detectado loop de chamadas de ferramentas Agenticas síncronas/raw sem Circuit Breaker perceptível. O agente corre risco de exaurir I/O local e cloud tokens." },
    { test: (l) => /semantic_search|compute_embeddings|exa_search/i.test(l) && !/threshold|cosine|similarity\s*>/i.test(l), msg: "🛡️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] VSS OMNI-HALLUCINATION: Busca semântica vetorial ou web acionadas sem validação de threshold/cosine similarity. Isso causará alucinação letal no contexto RAG (Retrieved context poisoning)." },
    { test: (l) => /query_arena_ai|agent_worker|swarm/i.test(l) && /await|Promise\.all/i.test(l) && !/circuitBreaker|timeoutMax/i.test(l), msg: "⚠️ [V112.0.0 OMNI-NEXUS TRANSCENDENCE] AGENTIC DEADLOCK (Swarm Paralisys): Sub-agentes ou modelos delegados engajados sem um limitador rústico de tempo ou tokens (Circuit Breaker duro). A colméia corre risco de entropia infinita na conversação." },
