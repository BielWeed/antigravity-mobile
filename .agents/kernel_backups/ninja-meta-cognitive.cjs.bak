if (process.stdout._handle && typeof process.stdout._handle.setBlocking === 'function') {
    process.stdout._handle.setBlocking(true);
}
if (process.stderr._handle && typeof process.stderr._handle.setBlocking === 'function') {
    process.stderr._handle.setBlocking(true);
}

const DB_PATH = path.join(__dirname, 'quasar_memory.db');
const LEARNINGS_PATH = path.join(__dirname, 'ninja-learnings-v3.json');
const ERRORS_FILE = path.resolve(__dirname, '../../../Downloads/Kimi_Agent_Atualização v4/ERRORS.md');

let db;

function scrub(text) {
    if (text == null) return text;
    let str = typeof text === 'object' ? JSON.stringify(text) : String(text);
    return str
        .replaceAll(/ghp_\w+/g, 'ghp_****')
        .replaceAll(/EXA_\w+/g, 'EXA_MASKED')
        .replaceAll(/FIGMA_\w+/g, 'FIGMA_MASKED');
}

async function initDB() {
    if (!db) {
        db = await open({ filename: DB_PATH, driver: sqlite3.Database });
        await db.exec(`
            CREATE TABLE IF NOT EXISTS entities (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT,
                type TEXT,
                description TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                UNIQUE(name, type)
            );
        `);
        // V73.0 Omni-Vacuum: Auto-limpeza de SQLite em memórias persistentes
        try { await db.exec('PRAGMA optimize;'); } catch(e) { console.error('[auto-heal]', e.message); }
    }
    return db;
}

const tools = [
    {
        name: "evaluate_logic",
        description: "Analisa um raciocínio lógico, trecho de código ou arquitetura em busca de anti-padrões conhecidos no ERRORS.md (System 2 Thinking).",
        inputSchema: { type: "object", properties: { logic_snippet: { type: "string" } }, required: ["logic_snippet"] }
    },
    {
        name: "record_lesson",
        description: "Grava uma nova regra ou aprendizado abstraído de um bug para memória persistente do Ninja.",
        inputSchema: { type: "object", properties: { subject: { type: "string" }, lesson: { type: "string" } }, required: ["subject", "lesson"] }
    },
    {
        name: "self_repair_prompt",
        description: "Gera um prompt focado em mitigação técnica com base nos anti-padrões e falhas recentes do Oracle e Error Log.",
        inputSchema: { type: "object", properties: { context: { type: "string" } } }
    }
];

let errorsCache = "";
let learningsCache = null;

async function loadErrorsMD() {
    try {
        errorsCache = await fs.promises.readFile(ERRORS_FILE, 'utf-8');
    } catch (e) {
        if (e.code !== 'ENOENT') {
            process.stderr.write(`[Meta] Could not read ERRORS.md: ${e.message}\n`);
        }
    }
}

async function loadLearnings() {
    try {
        const rawContent = await fs.promises.readFile(LEARNINGS_PATH, 'utf-8');
        learningsCache = JSON.parse(rawContent);
    } catch (e) {
        if (e.code !== 'ENOENT') {
            process.stderr.write(`[Meta] Erro parsing Learnings: ${e.message}\n`);
        }
    }
}

loadErrorsMD();
loadLearnings();

let debounceTimerE = null;
if (fs.existsSync(ERRORS_FILE)) {
    try {
        fs.watch(ERRORS_FILE, (eventType) => {
            clearTimeout(debounceTimerE);
            debounceTimerE = setTimeout(loadErrorsMD, 500);
        });
    } catch(e) { process.stderr.write(`[Meta] ERRORS_FILE watch error: ${e.message}\n`); }
}

let debounceTimerL = null;
if (fs.existsSync(LEARNINGS_PATH)) {
    try {
        fs.watch(LEARNINGS_PATH, (eventType) => {
            clearTimeout(debounceTimerL);
            debounceTimerL = setTimeout(loadLearnings, 500);
        });
    } catch(e) { process.stderr.write(`[Meta] LEARNINGS_PATH watch error: ${e.message}\n`); }
}

function readErrorsMD() {
    return errorsCache;
}

