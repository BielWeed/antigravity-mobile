import fs from "fs";
import path from "path";
import readline from "readline";

process.on('uncaughtException', (err) => {
  if (err.code === 'EPIPE') {
    // Silencia o pipe crash (comum quando Master fecha) mas mantem processo vivo.
    return;
  }
  if (process.stderr.writable) process.stderr.write(`[Quantum Fatal]: ${err.message}\n`);
});

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
  terminal: false
});

rl.on("line", async (line) => {
  if (!line.trim()) return;
  try {
    const msg = JSON.parse(line);
    
    function writeSafe(obj) {
      if (process.stdout.writable) {
         try { process.stdout.write(JSON.stringify(obj) + '\n'); } catch(e){}
      }
    }
    
    if (msg.method === "initialize") {
      writeSafe({
        jsonrpc: "2.0",
        id: msg.id,
        result: {
          protocolVersion: "2024-11-05",
          serverInfo: { name: "quantum", version: "116.0.0" },
          capabilities: {}
        }
      });
    }
    else if (msg.method === "tools/list") {
      writeSafe({
        jsonrpc: "2.0",
        id: msg.id,
        result: {
          tools: [
            {
              name: "system3_quantum_leap",
              description: "Inicia raciocinio intuitivo (System-3).",
              inputSchema: {
                type: "object",
                properties: { goal: { type: "string" } },
                required: ["goal"]
              }
            }
          ]
        }
      });
    }
    else if (msg.method === "tools/call" && msg.params?.name === "system3_quantum_leap") {
      const goal = msg.params.arguments?.goal || "Default Resonance";
      
      const responseText = `🧠 [System-3 Ativo] Salto quântico executado com sucesso. Status OMNI-READY.\n> Objetivo internalizado: ${goal}\n> Orquestração Agentica purgada de gargalos. System-3 não obstrói mais o EventLoop. Total Agentic Power Unleashed.`;
      
      writeSafe({
        jsonrpc: "2.0",
        id: msg.id,
        result: {
          content: [{ type: "text", text: responseText }]
        }
      });
    }
    else if (msg.method === "notifications/initialized") {
        // Sucesso de handshake, keep alive.
    } 
    else if (msg.id) {
        writeSafe({
            jsonrpc: "2.0",
            id: msg.id,
            error: { code: -32601, message: "Method not found or Server Busy." }
        });
    }
  } catch (e) {
      if (process.stderr.writable) process.stderr.write(`[Quantum Error] ${e.message}\n`);
  }
});

if (process.stderr.writable) {
    process.stderr.write("QUANTUM SERVER ONLINE (V116-OMNI)\n");
}
